# Environment Variables Template
# Copy this to .env and fill in your actual API keys
# NEVER commit .env to git - it's in .gitignore

# ============================================================================
# API KEYS (KEEP THESE SECRET - STORE IN .env ONLY)
# ============================================================================

# Groq API Key (for clinical agent and keyword extraction)
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google/Gemini API Key (for ROS scoring and chemical composition)
# Get free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# SerpAPI Key (for web search in market agent)
# Get free key at: https://serpapi.com/users/sign_up
SERPAPI_API_KEY=your_serpapi_key_here

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port
PORT=8000

# Environment (development, production, testing)
ENV=development

# ============================================================================
# DATABASE CONFIGURATION (Optional)
# ============================================================================

# PostgreSQL (if using database)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_postgres_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=maestro

# Neo4j (if using knowledge graph backend)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_neo4j_password

# ============================================================================
# LOGGING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# NOTES
# ============================================================================
# - This file (.env.example) is safe to commit to git
# - The actual .env file containing real keys is in .gitignore
# - Copy this to .env and add your real API keys
# - Never share your .env file or API keys
# - Rotate API keys regularly
# - Use different keys for different environments (dev, staging, prod)
